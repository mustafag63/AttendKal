{
  "name": "attendkal-backend",
  "version": "1.0.0",
  "description": "AttendKal Backend API - Student attendance tracking system",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "node --watch ./src/server.js",
    "build": "tsc -p . || echo 'skip if JS'",
    "start": "node ./dist/server.js || node ./src/server.js",
    "prisma:gen": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev --name init",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "db:reset": "prisma migrate reset --force",
    "seed:admin": "ts-node ./scripts/seedAdmin.ts || node --loader ts-node/esm ./scripts/seedAdmin.ts || node ./scripts/seedAdmin.ts",
    "test": "echo \"(add backend tests here)\" && exit 0",
    "dev:old": "nodemon src/server.js",
    "test:jest": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "db:studio": "prisma studio"
  },
  "keywords": [
    "attendance",
    "student",
    "education",
    "api",
    "nodejs",
    "express",
    "postgresql"
  ],
  "author": "AttendKal Team",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.651.1",
    "@prisma/client": "^5.22.0",
    "@types/node": "^24.2.1",
    "bcryptjs": "^2.4.3",
    "bull": "^4.16.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "express-validator": "^7.2.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.15",
    "pdf-lib": "^1.17.1",
    "pino": "^9.8.0",
    "pino-http": "^10.5.0",
    "prisma": "^5.22.0",
    "prom-client": "^15.1.3",
    "puppeteer": "^23.10.4",
    "sharp": "^0.33.5",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "directories": {
    "test": "tests"
  },
  "nodemonConfig": {
    "restartable": "rs",
    "ignore": [
      "node_modules/",
      "logs/",
      "coverage/",
      "*.test.js"
    ],
    "watch": [
      "src/"
    ],
    "ext": "js,json",
    "env": {
      "NODE_ENV": "development"
    },
    "delay": "1000",
    "exitcrash": true
  }
}
