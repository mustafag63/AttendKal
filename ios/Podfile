# ios/Podfile

require 'fileutils'

platform :ios, '13.0'   # veya projenizin ihtiyaç duyduğu minimum sürüm

ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug'   => :debug,
  'Profile' => :release,
  'Release' => :release,
}

# Flutter build settings yolunu doğru konumdan oku
def flutter_root
  # Podfile ile aynı dizindeki Flutter/Generated.xcconfig dosyasını kontrol et
  generated_xcode_build_settings_path = File.expand_path(File.join(__dir__, 'Flutter', 'Generated.xcconfig'))
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. Run 'flutter pub get' and ensure ios/Flutter/Generated.xcconfig is present"
  end
  File.foreach(generated_xcode_build_settings_path) do |line|
    if line =~ /FLUTTER_ROOT\=(.*)/
      return Regexp.last_match(1).strip
    end
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)
flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!
  use_modular_headers! # Use modular headers for better compatibility
  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))

  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    
    # Firebase ve tüm pods için agresif modular header düzeltmesi
    target.build_configurations.each do |config|
      # Modular includes sorununu tamamen çöz
      config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
      config.build_settings['DEFINES_MODULE'] = 'YES'
      config.build_settings['CLANG_ENABLE_MODULES'] = 'YES'
      config.build_settings['CLANG_MODULES_AUTOLINK'] = 'YES'
      
      # Firebase özel ayarları
      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= []
      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] << 'FIRMessaging_LIB_VERSION=@\"\"'
      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] << 'Firebase_VERSION=@\"\"'
      
      # Header search paths
      config.build_settings['HEADER_SEARCH_PATHS'] ||= []
      config.build_settings['HEADER_SEARCH_PATHS'] << '$(inherited)'
      config.build_settings['HEADER_SEARCH_PATHS'] << '"${PODS_ROOT}/Firebase"'
      config.build_settings['HEADER_SEARCH_PATHS'] << '"${PODS_ROOT}/Headers/Public"'
      
      # Warning'leri sustur
      config.build_settings['GCC_WARN_INHIBIT_ALL_WARNINGS'] = 'YES'
      config.build_settings['CLANG_WARN_DOCUMENTATION_COMMENTS'] = 'NO'
      
      # iOS deployment target
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
    end

    # --- BoringSSL-GRPC bayrak düzeltmesi ---
    if target.name == 'BoringSSL-GRPC'
      target.source_build_phase.files.each do |file|
        next unless file.settings && file.settings['COMPILER_FLAGS']
        flags = file.settings['COMPILER_FLAGS'].split
        flags.reject! { |f| f == '-GCC_WARN_INHIBIT_ALL_WARNINGS' }
        file.settings['COMPILER_FLAGS'] = flags.join(' ')
      end
    end

    # --- gRPC-Core header patch: remove 'template' keyword + izin düzeltmesi ---
    if target.name == 'gRPC-Core'
      pod_dir = installer.sandbox.pod_dir('gRPC-Core').to_s
      header = File.join(pod_dir, 'src', 'core', 'lib', 'promise', 'detail', 'basic_seq.h')
      if File.exist?(header)
        # 1) Dosyayı yazılabilir yap
        FileUtils.chmod('u+w', header)
        # 2) İçeriği oku ve patch uygula
        content = File.read(header)
        patched = content.gsub('Traits::template CallSeqFactory', 'Traits::CallSeqFactory')
        patched = patched.gsub('Traits::template CallSeqFactory<', 'Traits::CallSeqFactory<')
        File.write(header, patched)
        # 3) İzinleri eski haline döndür (isteğe bağlı)
        FileUtils.chmod('u-w', header)
      end
    end

    # --- gRPC-C++ header patch ---
    if target.name == 'gRPC-C++'
      pod_dir = installer.sandbox.pod_dir('gRPC-C++').to_s
      header = File.join(pod_dir, 'src', 'core', 'lib', 'promise', 'detail', 'basic_seq.h')
      if File.exist?(header)
        FileUtils.chmod('u+w', header)
        content = File.read(header)
        patched = content.gsub('Traits::template CallSeqFactory', 'Traits::CallSeqFactory')
        patched = patched.gsub('Traits::template CallSeqFactory<', 'Traits::CallSeqFactory<')
        File.write(header, patched)
        FileUtils.chmod('u-w', header)
      end
    end

    # Firebase Messaging özel header fix
    if target.name == 'firebase_messaging'
      target.build_configurations.each do |config|
        config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
        config.build_settings['GCC_WARN_INHIBIT_ALL_WARNINGS'] = 'YES'
        config.build_settings['CLANG_WARN_DOCUMENTATION_COMMENTS'] = 'NO'
      end
    end

    # This script fixes the 'port' undeclared identifier error in leveldb-library
    if target.name == 'leveldb-library'
      target.build_configurations.each do |config|
        config.build_settings['CC'] = '"$(TOOLCHAIN_DIR)/usr/bin/clang"'
        config.build_settings['CXX'] = '"$(TOOLCHAIN_DIR)/usr/bin/clang++"'
        config.build_settings['DEFINES_MODULE'] = 'YES'
        config.build_settings['COMPILER_FLAGS'] = '$(inherited) -Wno-error=shorten-64-to-32'
        
        leveldb_path = installer.sandbox.pod_dir('leveldb-library')
        
        # Patch port.h
        port_header = File.join(leveldb_path.to_s, 'port', 'port.h')
        if File.exist?(port_header)
          text = File.read(port_header)
          # Add include for <string> to fix build error
          if !text.include?('#include <string>')
            File.write(port_header, "#include <string>\n" + text)
            puts "✅ Patched port.h in leveldb-library"
          end
        end

        # Patch port_example.h
        port_example_header = File.join(leveldb_path.to_s, 'port', 'port_example.h')
        if File.exist?(port_example_header)
          text = File.read(port_example_header)
          # Add include for <string> to fix build error
          if !text.include?('#include <string>')
            File.write(port_example_header, "#include <string>\n" + text)
            puts "✅ Patched port_example.h in leveldb-library"
          end
        end
      end
    end
  end
end
